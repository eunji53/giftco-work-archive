# 이 파일은 예시입니다. 실제 값은 채우지 말고 변수명만 유지하세요.
# 실제 값은 .env 파일(gitignore 대상)에 별도로 작성합니다.

# --- projects/giftco-order-processing : FTP 이미지 수집 (ftp_download_sanitized.ipynb) ---
FTP_HOST=
FTP_PORT=21
FTP_USER=
FTP_PASSWORD=

# --- projects/giftco-order-processing : IMAP 메일 수집 (imap_mail_parser_sanitized.ipynb) ---
IMAP_HOST=
IMAP_PORT=993

# --- projects/giftco-order-processing : POP3 메일 수집 (pop_mail_v3_sanitized.ipynb) ---
POP3_HOST=
POP3_PORT=995

# --- IMAP/POP3 공통 계정 (imap_mail_parser_sanitized.ipynb, pop_mail_v3_sanitized.ipynb) ---
EMAIL_ADDR=
EMAIL_PASSWORD=

# --- projects/voice-data-pipeline : 회의록 작성.py (Anthropic API) ---
ANTHROPIC_API_KEY=

# --- projects/voice-data-pipeline : 01_analyze_inbound_calls.ipynb, analyze_inbound_calls.py (NAS 통화 녹음 경로) ---
# 예: \\NAS서버\mslab\DCS
VOICE_NAS_PATH=

# --- projects/giftco-supplier : 01_crawl_product_list.ipynb, 02_crawl_supplier_info.ipynb, giftco_supplier_crawler.py 공통 ---
# giftco.co.kr 로그인 후 F12 > Network 탭에서 Request Headers의 Cookie 값을 통째로 복사해서 붙여넣으세요.
GIFTCO_SUPPLIER_COOKIE=
